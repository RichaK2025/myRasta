# Copy this file to .env.local for local development.
# On Netlify: Site settings -> Environment variables -> add each of these,
# then trigger a new deploy (existing deploys don't pick up new env vars).

# MongoDB connection string (Atlas: mongodb+srv://user:pass@cluster.mongodb.net/)
# If this is missing/wrong, every write (saving a route) returns a JSON
# { error: "Database unavailable" } with a 503 status instead of a route id —
# this was the root cause of the "/r/undefined" share links.
MONGO_URL=
DB_NAME=raasta

# Google Sign-In (OAuth client from https://console.cloud.google.com/apis/credentials,
# type "Web application"). Add both http://localhost:3000 and
# https://myraasta.netlify.app to "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=
# Same value, exposed to the browser for the Google Identity Services button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=
